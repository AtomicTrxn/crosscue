{
  "name": "@crosscue/challenge-boards-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "smoke:local": "node scripts/smoke-local.mjs",
    "test": "node --experimental-strip-types --test test/**/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types",
    "d1:migrate:local": "wrangler d1 migrations apply crosscue_challenge_boards_local --local",
    "d1:migrate:staging": "wrangler d1 migrations apply crosscue_challenge_boards_staging --env staging",
    "d1:migrate:prod": "wrangler d1 migrations apply crosscue_challenge_boards_prod --env production"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.20.0"
  }
}
