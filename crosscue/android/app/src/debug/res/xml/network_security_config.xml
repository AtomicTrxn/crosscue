<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only (this file lives in the debug source set; release builds keep
     the platform default of no cleartext). Permits plain HTTP solely to the
     local challenge-boards Worker: 10.0.2.2 is the Android emulator's alias
     for the host's loopback, used by CHALLENGE_API_ENV=local. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
