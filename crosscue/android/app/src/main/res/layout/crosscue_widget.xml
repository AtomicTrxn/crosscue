<?xml version="1.0" encoding="utf-8"?>
<!-- Android home-screen widget (#204), parity with the iOS WidgetKit small
     widget. Stacked optional rows: streak / today / (future) leaderboard. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/crosscue_widget_background"
    android:padding="14dp">

    <!-- Streak -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <TextView
            android:id="@+id/widget_streak_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/crosscue_brand"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_streak_flame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="5dp"
            android:text="🔥"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.05"
        android:text="DAY STREAK"
        android:textColor="@color/crosscue_widget_subtle"
        android:textSize="11sp"
        android:textStyle="bold" />

    <!-- Spacer (TextView is RemoteViews-safe; Space is not). -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="" />

    <!-- Today -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.05"
        android:text="TODAY"
        android:textColor="@color/crosscue_widget_subtle"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_today_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Today's puzzle"
        android:textColor="@color/crosscue_widget_text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_today_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="▶ Solve"
        android:textColor="@color/crosscue_brand"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
